# Copy to .env and fill in. The .env file is .gitignore'd.

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override the default models (used by examples/common/config.py).
# Defaults are free GLM 4.5 Air (task) + Nemotron-3-super-120B (reflection).
# Alternative free task models if the default rate-limits:
#   openrouter/minimax/minimax-m2.5:free
#   openrouter/arcee-ai/trinity-large-preview:free
#   openrouter/openai/gpt-oss-120b:free
# Cheap paid fallbacks (~$0.10–$0.20 per million tokens):
#   openrouter/mistralai/ministral-8b-2512
#   openrouter/qwen/qwen3-30b-a3b-instruct-2507
# DSPY_TASK_MODEL=openrouter/z-ai/glm-4.5-air:free
# DSPY_REFLECTION_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free

# Optional: point DSPy's cache somewhere deterministic for reproducibility.
DSPY_CACHEDIR=.cache/dspy
